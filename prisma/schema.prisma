generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  username      String    @unique
  email         String    @unique
  password      String
  role          Role      @default(USER)
  avatarColor   String
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Airport {
  id              String   @id @default(cuid())
  openaipId       String   @unique
  name            String
  icaoCode        String?
  type            Int
  lat             Float
  lon             Float
  elevation       Float?
  elevationUnit   Int?
  country         String   @default("PL")
  geometry        Json?
  trafficType     Int[]
  ppr             Boolean  @default(false)
  private         Boolean  @default(false)
  skydiveActivity Boolean  @default(false)
  winchOnly       Boolean  @default(false)
  runways         Json?
  frequencies     Json?
  updatedAt       DateTime @updatedAt

  @@index([country])
  @@index([lat, lon])
}

model Airspace {
  id         String   @id @default(cuid())
  openaipId  String   @unique
  name       String
  type       Int
  icaoClass  Int?
  upperLimit Float?
  lowerLimit Float?
  country    String   @default("PL")
  geometry   Json
  updatedAt  DateTime @updatedAt

  @@index([country])
  @@index([type])
}

model Navaid {
  id              String    @id @default(cuid())
  openaipId       String    @unique
  name            String
  identifier      String?
  type            Int
  frequency       String?
  frequencyUnit   Int?
  channel         String?
  range           Float?
  rangeUnit       Int?
  lat             Float
  lon             Float
  elevation       Float?
  elevationUnit   Int?
  country         String    @default("PL")
  sourceUpdatedAt DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([country])
  @@index([lat, lon])
}

model Obstacle {
  id        String   @id @default(cuid())
  openaipId String   @unique
  type      Int
  lat       Float
  lon       Float
  elevation Float
  heightAgl Float
  country   String   @default("PL")
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([lat, lon])
}

model ReportingPoint {
  id        String   @id @default(cuid())
  openaipId String   @unique
  name      String
  type      Int?
  lat       Float
  lon       Float
  elevation Float?
  country   String   @default("PL")
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([lat, lon])
}

model SyncLog {
  id           String   @id @default(cuid())
  syncedAt     DateTime @default(now())
  itemsUpdated Int
  source       String
}

model AirspacePlan {
  id         String   @id @default(cuid())
  planDate   DateTime // UTC midnight of the day this plan is valid for
  planType   String // 'AUP' | 'UUP'
  designator String // normalised, e.g. "EPTS3F"
  lowerLimit String // e.g. "GND", "F095", "A020"
  upperLimit String // e.g. "F245", "A061"
  validFrom  String // HH:mm time string
  validTo    String // HH:mm time string
  unit       String? // controlling unit, e.g. "EPDE"
  fuaStatus  String? // 'Y' | 'N'
  remarks    String?
  syncedAt   DateTime @default(now())

  @@index([planDate])
  @@index([designator])
  @@index([planDate, designator])
}
